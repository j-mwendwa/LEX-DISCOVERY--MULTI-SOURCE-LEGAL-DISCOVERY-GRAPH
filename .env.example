# ─────────────────────────────────────────────
# LLM — HuggingFace (primary: Saul Legal AI)
# ─────────────────────────────────────────────
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL_ID=Equall/Saul-7B-Instruct-v1

# ─────────────────────────────────────────────
# LLM — Google Gemini (fallback)
# ─────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────
# Vector Store — Qdrant Cloud
# ─────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your_qdrant_cloud_api_key_here
VECTOR_BACKEND=qdrant

# ─────────────────────────────────────────────
# App / Auth
# ─────────────────────────────────────────────
ALLOWED_API_KEYS=["dev-local-key"]
APP_ENV=development

# ─────────────────────────────────────────────
# LangSmith Observability
# ─────────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=lex-discovery
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────────
# Memory Encryption (optional)
# ─────────────────────────────────────────────
MEMORY_ENCRYPTION_KEY=your_32_byte_base64_key_here
